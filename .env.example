# Copy to .env and fill in. The CLI loads it via --env-file-if-exists.
# On Vercel, set these same vars in Project Settings → Environment Variables.

# --- Supabase (database + image storage) ---
# Project Settings → API.  URL looks like https://xxxx.supabase.co
SUPABASE_URL=
# service_role key — SECRET, server-side only. Never ship to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Scrapers ---
# https://twitterapi.io        (X / Twitter)
TWITTERAPI_IO_KEY=
# https://apify.com/apify/instagram-scraper
APIFY_TOKEN=

# --- Cron protection ---
# Any random string. Vercel sends it as `Authorization: Bearer <CRON_SECRET>`
# to /api/ingest. Generate one: openssl rand -hex 24
CRON_SECRET=
