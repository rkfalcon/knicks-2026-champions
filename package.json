{
  "name": "knicks-2026-picture-book",
  "version": "1.0.0",
  "description": "A fan-made picture book of the New York Knicks' 2026 NBA Championship run, built from X & Instagram posts. Vercel + Supabase.",
  "type": "module",
  "private": true,
  "scripts": {
    "sample": "node scripts/sample.mjs",
    "ingest": "node --env-file-if-exists=.env scripts/ingest.mjs",
    "ingest:nomedia": "node --env-file-if-exists=.env scripts/ingest.mjs --no-media",
    "dev": "vercel dev",
    "serve": "cd . && python3 -m http.server 8080"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@vercel/edge": "^1.2.1",
    "@vercel/og": "^0.6.4"
  },
  "engines": { "node": ">=18" }
}
